{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",

  "functions": {
    "app/api/cfo/extract/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "app/api/assistant/chat/route.ts": {
      "maxDuration": 30
    },
    "app/api/admin/stats/route.ts": {
      "maxDuration": 30
    },
    "app/api/vendors/apply/route.ts": {
      "maxDuration": 15
    },
    "app/api/vendors/admin/decide/route.ts": {
      "maxDuration": 15
    }
  },

  "cleanUrls": true,
  "trailingSlash": false
}
